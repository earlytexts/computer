{
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env src/main.ts",
    "dev": "deno run --watch --allow-net --allow-read --allow-env src/main.ts",
    "test": "deno test --allow-read tests",
    "check": "deno check src/main.ts tests && deno lint && deno fmt --check"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@earlytexts/markit": "npm:@earlytexts/markit@^3.2.2",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "fmt": {
    "exclude": ["tests/fixtures/"]
  },
  "lint": {
    "exclude": ["tests/fixtures/"]
  }
}
