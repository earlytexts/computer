{
  "name": "@earlytexts/computer",
  "version": "0.2.0",
  "license": "MIT",
  "exports": {
    ".": "./src/client.ts",
    "./types": "./src/types.ts"
  },
  "tasks": {
    "start": "deno run --watch --allow-net --allow-read --allow-write --allow-env src/main.ts",
    "stdio": "deno run --allow-net --allow-read --allow-write --allow-env src/stdio.ts",
    "install": "git clone --depth 1 https://github.com/earlytexts/corpus $CORPUS_DIR",
    "build": "deno run --allow-read --allow-write --allow-env scripts/build-corpus.ts && deno run --allow-read --allow-write --allow-env src/build.ts",
    "dev:variants": "deno run --allow-read --allow-write --allow-env dev/variants.ts",
    "dev:lemmas": "deno run --allow-read --allow-write --allow-env dev/lemmas.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run --allow-net tests",
    "test:coverage": "deno test --allow-read --allow-write --allow-env --allow-run --allow-net --coverage --coverage-raw-data-only tests && deno coverage coverage --include=/computer/",
    "check": "deno check src dev tests scripts && deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@earlytexts/corpus/wire": "jsr:@earlytexts/corpus@^0.7.0/wire",
    "@earlytexts/corpus/build": "jsr:@earlytexts/corpus@^0.7.0/build",
    "@earlytexts/corpus/harness": "jsr:@earlytexts/corpus@^0.7.0/harness",
    "@earlytexts/markit": "jsr:@earlytexts/markit@^3.6.1",
    "@modelcontextprotocol/sdk/": "npm:/@modelcontextprotocol/sdk@1.29.0/",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "publish": {
    "include": [
      "src/client.ts",
      "src/types.ts",
      "README.md",
      "LICENSE.md",
      "deno.json"
    ]
  },
  "fmt": {
    "exclude": [
      "tests/fixtures/",
      "artefacts/",
      "dev/state/"
    ]
  },
  "lint": {
    "exclude": [
      "tests/fixtures/",
      "artefacts/",
      "dev/state/"
    ]
  }
}
